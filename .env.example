# =============================================================================
# IOT FLEET MONITOR PIPELINE — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env itself.
# =============================================================================

# -- Snowflake ----------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account.region.cloud
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=TRANSFORM_ROLE
SNOWFLAKE_WAREHOUSE=IOT_WH
SNOWFLAKE_DATABASE=IOT_PIPELINE

# -- AWS ----------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# -- S3 -----------------------------------------------------------------------
S3_BUCKET=iot-fleet-sensor-data-pipeline

# -- Lambda -------------------------------------------------------------------
LAMBDA_FUNCTION_NAME=iot-fleet-data-generator

# -- Error Simulation ---------------------------------------------------------
# Options: none, normal, high, extreme
ERROR_PROFILE=none
